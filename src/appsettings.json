{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Crawler": {
    "UrlsFile": "urls.json",
    "IndexPath": "index.txt",
    "OutputDir": "pages",
    "MaxPages": 100,
    "DelayMs": 50,
    "HttpTimeoutSeconds": 10,
    "UserAgent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36"
  },
  "AllowedHosts": "*"
}
